---
import AboutHero from '@/components/about/AboutHero.astro'
import AboutPageTitle from '@/components/about/AboutPageTitle'
import AboutSections from '@/components/about/AboutSections.astro'
// import Contributions from '@/components/about/contributions/Contributions'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { ExperienceTimeline } from '@/components/home/ExperienceTimeline'
import PageHead from '@/components/PageHead.astro'
import { EXPERIENCES } from '@/data/experiences'
import Layout from '@/layouts/Layout.astro'
