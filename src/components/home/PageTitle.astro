---
interface Props {
  title?: string
  titleJP?: string
  subTitle?: string
}

const { title, titleJP, subTitle } = Astro.props
---

<div class="mb-6 mt-3 text-center">
  <h2
    class="text-foreground font-bold text-xl"
    title={title}
  >
    {titleJP ?? ''}
  </h2>
  {subTitle && (
    <p class="text-muted-foreground mt-1 font-sans">{subTitle}</p>
  )}
</div>
