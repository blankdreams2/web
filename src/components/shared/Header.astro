---
import { HeaderLogo } from '@/components/HeaderLogo'
import Link from '@/components/Link.astro'
import NavIconQuickAccess from '@/components/quick-access/NavIconQuickAccess.astro'
import { NAV_LINKS } from '@/consts'
import { Image } from 'astro:assets'
---

<div class='min-w-0 overflow-hidden'>
  <div
    class='mx-auto flex w-full max-w-3xl min-w-0 items-center justify-between gap-4 overflow-hidden px-4 py-3'
  >
    <!-- logo -->
    <Link href='/' class='flex shrink-0 items-center gap-3'>
      <Image
        src='/static/coffee.png'
        width={200}
        height={200}
        alt='Logo'
        class='size-5 shrink-0 rounded-2xl sm:size-6'
      />
      <HeaderLogo client:load />
    </Link>

    <!-- desktop nav links (hidden on mobile - nav lives in Quick Access there) -->
    <nav class='ml-auto hidden items-center gap-1 xl:flex' aria-label='Main navigation'>
      {
        NAV_LINKS.map((item) => (
          <Link
            href={item.href}
            class='text-muted-foreground hover:text-foreground hover:bg-muted/50 rounded-lg px-3 py-2 text-sm font-medium transition-colors'
          >
            {item.label}
          </Link>
        ))
      }
    </nav>

    <!-- Quick Access (mobile: nav inside; desktop: shortcuts/theme/focus) -->
    <NavIconQuickAccess />
  </div>
</div>
