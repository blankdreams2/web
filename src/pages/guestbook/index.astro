---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { ConvexClientProvider } from '@/components/guestbook/ConvexClientProvider'
import { Guestbook } from '@/components/guestbook/Guestbook'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
---

<Layout class='max-w-2xl'>
  <PageHead slot='head' title='Guestbook' />
  <div class='space-y-6'>
    <Breadcrumbs items={[{ label: 'Guestbook', icon: 'lucide:book-open' }]} />
    <h1 class='font-display text-2xl font-bold sm:text-3xl'>Guestbook</h1>
    <p class='text-muted-foreground text-sm'>Leave an anonymous message. No login required.</p>
    <ConvexClientProvider client:load>
      <Guestbook />
    </ConvexClientProvider>
  </div>
</Layout>
