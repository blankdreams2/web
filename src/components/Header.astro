---
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import { NAV_LINKS, SITE } from '@/consts'
import { Image } from 'astro:assets'

// import logo from '../../public/static/logo.svg'
import logo from '../../public/static/1122.png'
---

<div>
  <div class='mx-auto flex w-full max-w-3xl items-center justify-between gap-4 px-4 py-3'>
    {/* LEFT: logo + (mobile) nav */}
    <div class='flex min-w-0 items-center gap-3'>
      <!-- logo -->
      <Link href='/' class='flex shrink-0 items-center justify-center gap-3'>
        <Image src={logo} alt='Logo' class='size-5 rounded-2xl sm:size-6' />
        <span class='hidden h-full text-lg leading-none font-medium min-[400px]:block'
          >{SITE.title}</span
        >
      </Link>

      {/* mobile nav (<= sm) */}
      <nav class='flex items-center gap-3 text-sm sm:hidden' aria-label='Primary'>
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class='text-foreground/60 hover:text-foreground transition-colors'
            >
              {item.label}
            </Link>
          ))
        }
      </nav>
    </div>

    {/* RIGHT: (desktop) nav + theme toggle */}
    <div class='flex items-center gap-4'>
      {/* Desktop nav (sm and up) */}
      <nav class='hidden items-center gap-4 text-sm sm:flex sm:gap-6' aria-label='Primary'>
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class='text-foreground/60 hover:text-foreground transition-colors'
            >
              {item.label}
            </Link>
          ))
        }
      </nav>

      <ThemeToggle transition:persist />
    </div>
  </div>
</div>
