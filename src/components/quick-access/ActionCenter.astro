---
import { AnimatedThemeToggler } from '@/components/ui/animated-theme-toggler'
---
<!-- Action Center -->
<div class='flex flex-col gap-2'>
  <h3 class='text-muted-foreground px-2 text-xs font-semibold tracking-wider uppercase'>
    Action Center
  </h3>

  <!-- Action Center Buttons -->
  <div class='flex flex-1 flex-col gap-8 p-2'>
    <div class='flex h-16 gap-4'>
      <!-- Theme Toggle -->
      <div
        class='bg-muted/50 hover:bg-muted/70 flex flex-1 items-center justify-between gap-3 overflow-hidden rounded-xl px-4 py-3 transition-colors'
      >
        <span class='text-[13px] font-medium'>Dark Mode</span>
        <AnimatedThemeToggler client:load className='size-9 shrink-0 rounded-lg' />
      </div>

      <!-- Focus Mode Toggle -->
      <button
        type='button'
        id='action-focus'
        class='action-center-btn bg-muted/50 hover:bg-muted/70 relative flex flex-1 items-center justify-between overflow-hidden rounded-xl px-4 py-3 transition-colors'
      >
        <div class='text-muted-foreground flex shrink-0 items-center justify-center'>
          <span class='action-focus-icon-off'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='20'
              height='20'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
            >
              <path d='M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z'></path>
              <circle cx='12' cy='12' r='3'></circle>
            </svg>
          </span>
          <span class='action-focus-icon-on hidden'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='20'
              height='20'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
            >
              <path d='M10.733 5a3 3 0 0 1 2.534 0'></path>
              <path d='M17.252 4.03A10 10 0 0 0 4.03 17.25'></path>
              <path d='M19.03 6.75a10 10 0 0 0-13.28 13.28'></path>
              <path d='M14 12a2 2 0 0 1-2 2'></path>
              <path d='M2 2l20 20'></path>
            </svg>
          </span>
        </div>
        <div class='text-[13px] font-medium'>
          Focus: <span class='action-focus-label text-muted-foreground'>Off</span>
        </div>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  ;(function () {
    function initFocus() {
      const btn = document.getElementById('action-focus')
      const label = btn?.querySelector('.action-focus-label')
      const iconOff = btn?.querySelector('.action-focus-icon-off')
      const iconOn = btn?.querySelector('.action-focus-icon-on')

      function update() {
        const on = document.documentElement.classList.contains('focus-mode')
        if (label) label.textContent = on ? 'On' : 'Off'
        if (iconOff) iconOff.classList.toggle('hidden', on)
        if (iconOn) iconOn.classList.toggle('hidden', !on)
      }

      btn?.addEventListener('click', () => {
        document.documentElement.classList.toggle('focus-mode')
        update()
      })

      window.addEventListener('focus-mode-change', update)
      update()
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFocus)
    } else {
      initFocus()
    }
  })()
</script>
