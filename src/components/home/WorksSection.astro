---
import Link from '@/components/Link.astro'
import { Badge } from '@/components/ui/badge'
import { buttonVariants } from '@/components/ui/button'
import { Icon } from 'astro-icon/components'
import { PLACEHOLDER_PROJECTS } from '@/data/works'

---

<section class="mt-16 flex flex-col">
  <h2 class="text-5xl font-bold">
    Works<span class="text-accent">.</span>
  </h2>
  <p class="text-muted-foreground mb-6 text-2xl">
    Stuff, I've{' '}
    <span
      class="text-foreground font-serif italic underline decoration-accent underline-offset-4"
    >
      Built
    </span>{' '}
    ehm...recently
  </p>

  <ul class="flex flex-col gap-6">
    {
      PLACEHOLDER_PROJECTS.map((project) => (
        <li
          class="hover:bg-muted/50 flex flex-col gap-4 rounded-xl border p-4 transition-colors sm:flex-row"
        >
          <!-- image placeholder -->
          <div class="bg-muted flex aspect-video w-full shrink-0 items-center justify-center rounded-lg sm:max-w-48">
            <span class="text-muted-foreground text-4xl">📦</span>
          </div>

          <div class="flex min-w-0 flex-1 flex-col gap-2">
            <h3 class="text-lg font-bold">{project.name}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {
                project.tags.map((tag) => (
                  <Badge variant="muted">{tag}</Badge>
                ))
              }
            </div>
            <div class="mt-2 flex flex-wrap gap-2">
              <Link
                href={project.sourceHref}
                class={buttonVariants({ variant: 'outline', size: 'sm' })}
              >
                <Icon name="lucide:code" class="size-4" />
                Source Code
              </Link>
              <Link
                href={project.siteHref}
                class={buttonVariants({ variant: 'outline', size: 'sm' })}
              >
                Visit Site
                <Icon name="lucide:arrow-right" class="size-4" />
              </Link>
            </div>
          </div>
        </li>
      ))
    }
  </ul>

  <div class="mt-6 flex justify-center">
    <Link
      href="/project"
      class="text-muted-foreground hover:text-foreground group inline-flex items-center gap-2 text-sm transition-colors"
    >
      See all projects
      <span class="transition-transform group-hover:translate-x-1">▷</span>
    </Link>
  </div>
</section>
