---
import { HeaderLogo } from '@/components/HeaderLogo'
import Link from '@/components/Link.astro'
import NavIconQuickAccess from '@/components/NavIconQuickAccess.astro'
import { Image } from 'astro:assets'
---

<div class="min-w-0 overflow-hidden">
    <div class='mx-auto flex w-full max-w-3xl min-w-0 items-center justify-between gap-4 overflow-hidden px-4 py-3'>
    <!-- logo -->
    <Link href='/' class='flex shrink-0 items-center gap-3'>
      <Image
        src='/static/coffee.png'
        width={200}
        height={200}
        alt='Logo'
        class='size-5 shrink-0 rounded-2xl sm:size-6'
      />
      <span class='hidden min-w-0 overflow-hidden text-ellipsis whitespace-nowrap text-lg leading-none font-medium sm:block'>
        <HeaderLogo client:load />
      </span>
    </Link>

    <!-- Quick Access - nav lives inside -->
    <NavIconQuickAccess />
  </div>
</div>
