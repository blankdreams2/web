---
import { ActionCenterThemeCard } from './ActionCenterThemeCard'
---

<div class='flex flex-col gap-2'>
  <h3 class='text-muted-foreground px-2 text-xs font-semibold tracking-wider uppercase'>
    Action Center
  </h3>

  <div class='flex flex-1 flex-col gap-8 p-2'>
    <div class='flex h-24 gap-4'>
      <!-- Theme Toggle (AnimatedThemeToggler) -->
      <ActionCenterThemeCard client:load />

      <!-- Focus Toggle -->
      <button
        type='button'
        id='action-focus'
        class='action-center-focus relative flex flex-1 flex-col justify-between overflow-hidden rounded-xl p-4 transition-colors bg-muted/30'
      >
        <div class='flex h-9 w-9 shrink-0 items-center justify-center'>
          <span class='action-focus-off' aria-hidden>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='20'
              height='20'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
            >
              <path d='M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z'></path>
              <circle cx='12' cy='12' r='3'></circle>
            </svg>
          </span>
          <span class='action-focus-on hidden' aria-hidden>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              width='20'
              height='20'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
            >
              <path d='M10.733 5a3 3 0 0 1 2.534 0'></path>
              <path d='M17.252 4.03A10 10 0 0 0 4.03 17.25'></path>
              <path d='M19.03 6.75a10 10 0 0 0-13.28 13.28'></path>
              <path d='M14 12a2 2 0 0 1-2 2'></path>
              <path d='M2 2l20 20'></path>
            </svg>
          </span>
        </div>
        <div class='text-left text-[13px] font-medium dark:font-normal'>
          Focus: <span class='action-focus-label'>Off</span>
        </div>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  ;(function () {
    function getFocus() {
      return document.documentElement.classList.contains('focus-mode')
    }

    function updateFocusUI() {
      const on = getFocus()
      const btn = document.getElementById('action-focus')
      const label = btn?.querySelector('.action-focus-label')
      const iconOff = btn?.querySelector('.action-focus-off')
      const iconOn = btn?.querySelector('.action-focus-on')

      if (label) label.textContent = on ? 'On' : 'Off'
      if (iconOff) iconOff.classList.toggle('hidden', on)
      if (iconOn) iconOn.classList.toggle('hidden', !on)
      if (btn) {
        btn.classList.toggle('bg-muted', on)
        btn.classList.toggle('bg-muted/30', !on)
      }
    }

    function init() {
      const focusBtn = document.getElementById('action-focus')

      focusBtn?.addEventListener('click', () => {
        document.documentElement.classList.toggle('focus-mode')
        updateFocusUI()
        window.dispatchEvent(new CustomEvent('focus-mode-change'))
      })

      window.addEventListener('focus-mode-change', updateFocusUI)
      updateFocusUI()
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init)
    } else {
      init()
    }
  })()
</script>
