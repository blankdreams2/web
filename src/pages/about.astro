---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllProjects } from '@/lib/data-utils'

const projects = await getAllProjects()
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <section>
    <div class="min-w-full">
      <div class="prose mb-8">
        <h3 class="mt-0">chào, or hi there.</h3>
        <p>
          started coding in 2021 and I've been kinda like? it. While I may not be
          deeply curious about how "computer" works but I do want to see how they
          come together and literally create dark magic, and that's how this website
          was made.
        </p>
        <p>
          lately I've been exploring UI/UX, pixel-art interfaces, and a
          lot of CTFs. I also care about clean, fast web experiences and small
          tools that feel nice to use.
        </p>
        <p>
          If you're curious about the code, it's open-source (old web, writing the new one right now)at
          <Link href="https://github.com/thienguen/website" external underline
            >@thienguen/website</Link
          >.
        </p>
      </div>

      <h2 class="mb-4 text-2xl font-medium">Projects</h2>
      <div class="flex flex-col gap-4">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</Layout>
