---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageTitle from '@/components/home/PageTitle.astro'
import PageHead from '@/components/PageHead.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import PaginationComponent from '@/components/ui/pagination'
import { SITE } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { getAllProjects } from '@/lib/data-utils'
import type { PaginateFunction } from 'astro'
import { Icon } from 'astro-icon/components'
import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allProjects = await getAllProjects()
  return paginate(allProjects, { pageSize: SITE.projectsPerPage })
}

const { page } = Astro.props
---

<Layout class='max-w-3xl'>
  <PageHead slot='head' title='project' />
  <PageTitle titleJP='注目プロジェクト。'>
    <Breadcrumbs
      slot='breadcrumbs'
      items={[
        { label: 'project', icon: 'lucide:sparkle' },
        { label: `Page ${page.currentPage}`, icon: 'lucide:book-copy' },
      ]}
    />
  </PageTitle>

  <!-- TODO: do I need to make it into a component? -->
  <section class='flex flex-col'>
    {
      page.data.length > 0 ? (
        <ul class='flex flex-col gap-6'>
          {page.data.map((project: CollectionEntry<'projects'>) => (
            <li>
              <ProjectCard project={project} />
            </li>
          ))}
        </ul>
      ) : (
        <div
          class='bg-muted/30 flex flex-col items-center justify-center gap-4 rounded-xl border border-dashed py-16 text-center'
          role='status'
        >
          <Icon name='lucide:folder-open' class='text-muted-foreground size-12' />
          <p class='text-muted-foreground text-lg'>Nothing here yet.</p>
          <p class='text-muted-foreground/80 text-sm'>
            Add projects in{' '}
            <code class='bg-muted rounded px-1.5 py-0.5 font-mono text-xs'>
              src/content/projects/
            </code>
          </p>
        </div>
      )
    }
  </section>

  <PaginationComponent
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    baseUrl='/project/'
    client:load
  />
</Layout>
