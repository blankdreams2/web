---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageTitle from '@/components/home/PageTitle.astro'
import PageHead from '@/components/PageHead.astro'
import { BentoProjectGrid } from '@/components/project/BentoProjectGrid'
import Layout from '@/layouts/Layout.astro'
import { getAllProjects } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'
import type { CollectionEntry } from 'astro:content'

const allProjects = await getAllProjects()
function serializeProject(p: CollectionEntry<'projects'>) {
  const img = p.data.image as unknown
  let imageSrc: string | null = null
  if (img) {
    if (typeof img === 'string') {
      imageSrc = (img as string).startsWith('/public') ? (img as string).slice(7) : (img as string)
    } else if (typeof img === 'object' && img !== null && 'src' in img) {
      imageSrc = (img as { src?: string }).src ?? null
    }
  }
  return {
    id: p.id,
    name: p.data.name,
    description: p.data.description,
    link: p.data.link,
    image: imageSrc,
    tags: p.data.tags ?? [],
    startDate: p.data.startDate?.toISOString() ?? null,
    endDate: p.data.endDate?.toISOString() ?? null,
  }
}
const serializedProjects = allProjects.map(serializeProject)
---

<Layout class='max-w-5xl'>
  <PageHead slot='head' title='project' />
  <PageTitle titleJP='注目プロジェクト。'>
    <Breadcrumbs slot='breadcrumbs' items={[{ label: 'project', icon: 'lucide:sparkle' }]} />
  </PageTitle>

  <!-- TODO: make it into a component -->
  <section class='flex flex-col'>
    {
      allProjects.length > 0 ? (
        <BentoProjectGrid projects={serializedProjects} client:load />
      ) : (
        <div
          class='bg-muted/30 flex flex-col items-center justify-center gap-4 rounded-xl border border-dashed py-16 text-center'
          role='status'
        >
          <Icon name='lucide:folder-open' class='text-muted-foreground size-12' />
          <p class='text-muted-foreground text-lg'>Nothing here yet.</p>
          <p class='text-muted-foreground/80 text-sm'>
            Add projects in{' '}
            <code class='bg-muted rounded px-1.5 py-0.5 font-mono text-xs'>
              src/content/projects/
            </code>
          </p>
        </div>
      )
    }
  </section>
</Layout>
