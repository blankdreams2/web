---
import Link from '@/components/shared/Link.astro'
import { Badge } from '@/components/ui/badge'
import {
  getSubpostCount,
  getSubpostsForParent,
  isSubpost
} from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  entry: CollectionEntry<'blog'>
}

const { entry } = Astro.props
// const formattedDate = formatDate(entry.data.date)
// const readTime = await getCombinedReadingTime(entry.id)
// const authors = await parseAuthors(entry.data.authors ?? [])
const subpostCount = !isSubpost(entry?.id) ? await getSubpostCount(entry?.id) : 0
const subposts =
  subpostCount > 0 && !isSubpost(entry?.id) ? await getSubpostsForParent(entry?.id) : []
---

<div class='hover:bg-muted/50 rounded-xl border p-4 transition-colors duration-300 ease-in-out'>
  <Link href={`/${entry.collection}/${entry.id}`} class='flex flex-col gap-4 sm:flex-row'>
    {
      (() => {
        const img = entry.data.image as unknown
        if (!img) return null
        if (typeof img === 'string') {
          const src = img.startsWith('/public') ? img.slice(7) : img
          return (
            <div class='w-full sm:max-w-3xs sm:shrink-0'>
              <img src={src} alt={entry.data.title} class='object-cover' />
            </div>
          )
        }
        return (
          <div class='w-full sm:max-w-3xs sm:shrink-0'>
            <Image
              src={img as import('astro').ImageMetadata}
              alt={entry.data.title}
              width={1200}
              height={630}
              class='object-cover'
            />
          </div>
        )
      })()
    }

    <div class='grow'>
      <h3 class='mb-1 text-lg font-medium'>{entry.data.title}</h3>
      <p class='text-muted-foreground mb-2 text-sm'>{entry.data.description}</p>

      {
        entry.data.tags && (
          <div class='flex flex-wrap gap-2'>
            {entry.data.tags.map((tag) => (
              <Badge variant='muted' className='flex items-center gap-x-1'>
                <Icon name='lucide:hash' class='size-3' />
                {tag}
              </Badge>
            ))}
          </div>
        )
      }
    </div>
  </Link>

  {
    subposts.length > 0 && (
      <div class='mt-3 border-t pt-3'>
        <div class='text-muted-foreground mb-2 text-xs'>Subposts</div>
        <ul class='list-inside list-disc space-y-1 text-sm'>
          {subposts.slice(0, 6).map((sp) => (
            <li>
              <Link
                href={`/${sp.collection}/${sp.id}`}
                class='hover:text-foreground text-muted-foreground underline-offset-4 hover:underline'
              >
                {sp.data.title}
              </Link>
            </li>
          ))}
          {subposts.length > 6 && (
            <li>
              <Link
                href={`/${entry.collection}/${entry.id}`}
                class='hover:text-foreground text-muted-foreground underline-offset-4 hover:underline'
              >
                View all →
              </Link>
            </li>
          )}
        </ul>
      </div>
    )
  }
</div>
