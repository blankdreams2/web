---
interface Props {
  posts: { slug: string; title: string; date: string }[]
}

const { posts } = Astro.props
---

<div class="flex flex-col gap-2">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
    Recent Posts
  </h3>
  {posts.length === 0 ? (
    <p class="text-sm text-muted-foreground">No posts yet.</p>
  ) : (
    <ul class="flex flex-col gap-1">
      {posts.map((post) => (
        <li>
          <a
            href={`/blog/${post.slug}`}
            class="quick-access-link flex items-center gap-2 rounded-lg px-2 py-1.5 text-sm hover:bg-muted/50 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 text-muted-foreground">
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
              <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
            </svg>
            <span class="truncate">{post.title}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</div>
