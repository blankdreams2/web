---
import AboutHero from '@/components/about/AboutHero.astro'
import AboutPageTitle from '@/components/about/AboutPageTitle'
import AboutSections from '@/components/about/AboutSections.astro'
import { SpinPenguin } from '@/components/about/SpinPenguin'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { ExperienceTimeline } from '@/components/home/ExperienceTimeline'
import PageHead from '@/components/PageHead.astro'
import { EXPERIENCES } from '@/data/experiences'
import Layout from '@/layouts/Layout.astro'
---

<Layout class='max-w-3xl'>
  <PageHead slot='head' title='About' />
  <AboutPageTitle client:load>
    <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />
  </AboutPageTitle>
  <AboutHero />
  <AboutSections />
  <ExperienceTimeline client:load experiences={EXPERIENCES} />
  <SpinPenguin client:load />
</Layout>
