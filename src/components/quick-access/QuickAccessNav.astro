---
import { NAV_LINKS } from '@/consts'
---

<div class='flex flex-col gap-2'>
  <h3 class='text-muted-foreground text-xs font-semibold tracking-wider uppercase'>Navigation</h3>
  <nav class='flex flex-col gap-1' aria-label='Quick navigation'>
    {
      NAV_LINKS.map((item) => (
        <a
          href={item.href}
          class='quick-access-link hover:bg-muted/50 active:bg-muted/70 flex min-h-11 items-center gap-2 rounded-lg px-3 py-2.5 text-base transition-colors'
        >
          <span>{item.label}</span>
        </a>
      ))
    }
  </nav>
</div>
