---
interface Props {
  titleJP?: string
  subTitle?: string
}

const { titleJP, subTitle } = Astro.props
---

<div class="mb-6 mt-3 text-center">
  <h2 class="text-xl font-bold text-foreground">
    {titleJP ?? ''}
  </h2>
  {subTitle && <p class="text-muted-foreground mt-1 font-sans">{subTitle}</p>}
</div>
