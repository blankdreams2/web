---
import { NAV_LINKS } from '@/consts'
---

<div class="flex flex-col gap-2">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
    Navigation
  </h3>
  <nav class="flex flex-col gap-1" aria-label="Quick navigation">
    {NAV_LINKS.map((item) => (
      <a
        href={item.href}
        class="quick-access-link flex min-h-11 items-center gap-2 rounded-lg px-3 py-2.5 text-base transition-colors hover:bg-muted/50 active:bg-muted/70"
      >
        <span>{item.label}</span>
      </a>
    ))}
  </nav>
</div>
